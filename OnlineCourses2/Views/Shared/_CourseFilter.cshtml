@model dynamic

<form method="get" class="course-filter">

    <!-- Search -->
    <input type="text"
           name="search"
           value="@ViewBag.Search"
           class="search-box"
           placeholder="Търси курс или категория" />

    <!-- Filter button -->
    <button type="button" id="filterToggle" class="filter-icon">
        <i class="bi bi-funnel"></i>
    </button>

    <!-- Filters -->
    <div id="filterControls" class="filter-row hidden-filter">

        <!-- Category -->
        <select name="categoryId" class="filter-select category-select">
            <option value="">Всички категории</option>
            @foreach (var c in ViewBag.Categories)
            {
                <option value="@c.Id"
                        selected="@(ViewBag.CategoryId == c.Id ? "selected" : null)">
                    @c.Name
                </option>
            }
        </select>

        <!-- Sort -->
        <select name="sort" class="filter-select sort-select">
            <option value="">Без подреждане</option>
            <option value="name_asc" selected="@(ViewBag.Sort == "name_asc")">Име (A–Z)</option>
            <option value="name_desc" selected="@(ViewBag.Sort == "name_desc")">Име (Z–A)</option>
            <option value="price_low" selected="@(ViewBag.Sort == "price_low")">Цена ↑</option>
            <option value="price_high" selected="@(ViewBag.Sort == "price_high")">Цена ↓</option>
            <option value="days_low" selected="@(ViewBag.Sort == "days_low")">Дни ↑</option>
            <option value="days_high" selected="@(ViewBag.Sort == "days_high")">Дни ↓</option>
            <option value="hours_low" selected="@(ViewBag.Sort == "hours_low")">Часове ↑</option>
            <option value="hours_high" selected="@(ViewBag.Sort == "hours_high")">Часове ↓</option>
        </select>

        <!-- Certificate -->
        <select name="certificate" class="filter-select certificate-select">
            <option value="">Сертификат (всички)</option>
            <option value="yes" selected="@(ViewBag.Certificate == "yes")">Да</option>
            <option value="no" selected="@(ViewBag.Certificate == "no")">Не</option>
        </select>

        <!-- Buttons -->
        <button type="submit" class="apply-btn">Приложи</button>
        <button type="button" id="resetFilters" class="reset-btn">Нулирай</button>

    </div>

</form>


<script>
document.addEventListener("DOMContentLoaded", function () {

    const toggle = document.getElementById("filterToggle");
    const panel = document.getElementById("filterControls");
    const resetBtn = document.getElementById("resetFilters");

    // toggle filter
    toggle.addEventListener("click", function (e) {
        e.stopPropagation();
        panel.classList.toggle("hidden-filter");
    });

    // close only when clicking outside
    document.addEventListener("click", function (e) {
        if (!panel.contains(e.target) && !toggle.contains(e.target)) {
            panel.classList.add("hidden-filter");
        }
    });

    // reset (НЕ затваря, защото ще има query param)
    resetBtn.addEventListener("click", function () {
        window.location.href = window.location.pathname + "?reset=true";
    });

    // ако има query → отвори филтъра
    if (window.location.search.length > 0) {
        panel.classList.remove("hidden-filter");
    }

    // махаме reset=true от URL (по желание)
    if (window.location.search.includes("reset=true")) {
        const url = new URL(window.location);
        url.searchParams.delete("reset");
        window.history.replaceState({}, document.title, url.pathname);
    }

});
</script>

<script>
window.addEventListener("load", function () {

    console.log("Select2 INIT AFTER LOAD");

    if ($.fn.select2) {

       $('.category-select').select2({
    width: '180px',
    dropdownParent: $('#filterControls')
});

$('.sort-select').select2({
    minimumResultsForSearch: Infinity,
    width: '180px',
    dropdownParent: $('#filterControls')
});
    $('.certificate-select').select2({
    minimumResultsForSearch: Infinity,
    width: '180px',
    dropdownParent: $('#filterControls')
});

    } else {
        console.error("Select2 НЕ е зареден!");
    }
});

</script>


